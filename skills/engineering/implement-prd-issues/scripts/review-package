#!/usr/bin/env bash
# Generate a review package containing commit list, stat summary, and net diff.
# The package is passed to reviewer subagents as a file path.
#
# Usage: review-package BASE HEAD [OUTFILE]
set -euo pipefail

if [ "$#" -lt 2 ] || [ "$#" -gt 3 ]; then
  echo "usage: review-package BASE HEAD [OUTFILE]" >&2
  exit 2
fi

base=$1
head=$2

git rev-parse --verify --quiet "$base" >/dev/null || {
  echo "bad BASE: $base" >&2
  exit 2
}

git rev-parse --verify --quiet "$head" >/dev/null || {
  echo "bad HEAD: $head" >&2
  exit 2
}

if [ "$#" -eq 3 ]; then
  out=$3
else
  dir=$(git rev-parse --git-path implement-prd-issues)
  mkdir -p "$dir"
  dir=$(cd "$dir" && pwd)
  out="$dir/review-$(git rev-parse --short "$base")..$(git rev-parse --short "$head").diff"
fi

{
  echo "# Review package: ${base}..${head}"
  echo
  echo "## Commits"
  git log --oneline "${base}..${head}"
  echo
  echo "## Files changed"
  git diff --stat "${base}..${head}"
  echo
  echo "## Diff"
  git diff -U10 "${base}..${head}"
} > "$out"

commits=$(git rev-list --count "${base}..${head}")
bytes=$(wc -c < "$out" | tr -d ' ')
echo "wrote $out: ${commits} commit(s), ${bytes} bytes"
